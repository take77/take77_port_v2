---
import { getCollection } from "astro:content";
import SectionTitle from "../common/SectionTitle.astro";
import WorkCard from "../works/WorkCard.astro";

const categoryColors: Record<string, string> = {
  "system-development": "#6366f1",
  "web-development": "#8b5cf6",
  "business-planning": "#06b6d4",
  "video-editing": "#ec4899",
};

// Fetch featured works, sorted by date descending
const featuredWorks = await getCollection("works", ({ data }) =>
  !data.draft && data.featured
);

const sortedFeatured = featuredWorks.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

// Fallback: supplement with non-featured works if fewer than 3 featured exist
let works = sortedFeatured.slice(0, 3);
if (works.length < 3) {
  const nonFeatured = await getCollection("works", ({ data }) =>
    !data.draft && !data.featured
  );
  const sortedNonFeatured = nonFeatured.sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime()
  );
  works = [...works, ...sortedNonFeatured].slice(0, 3);
}
---

<section id="works" class="featured-works-section">
  <div class="featured-works-inner">
    <SectionTitle accent="Featured Works" title="Works" subtitle="実績ハイライト" />

    <div class="works-grid">
      {works.map((work) => {
        const primaryCategory = work.data.serviceCategory[0];
        const themeColor = categoryColors[primaryCategory] ?? "#8b5cf6";
        // work.id is like "corporate-site-redesign/index" from glob loader
        const slug = work.id.split("/")[0];

        return (
          <WorkCard
            slug={slug}
            title={work.data.title}
            description={work.data.description}
            thumbnail={work.data.thumbnail}
            serviceCategory={work.data.serviceCategory}
            themeColor={themeColor}
            technologies={work.data.technologies.slice(0, 4)}
          />
        );
      })}
    </div>

    <div class="works-more">
      <a href="/works" class="works-all-link">すべての実績を見る →</a>
    </div>
  </div>
</section>

<style>
  .featured-works-section {
    padding: 80px clamp(24px, 6vw, 80px);
  }

  .featured-works-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  /* Grid: 3 columns → 2 (tablet) → 1 (mobile) */
  .works-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 2.5rem; /* title → card separation */
  }

  @media (max-width: 1024px) {
    .works-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .works-grid {
      grid-template-columns: 1fr;
    }
  }

  /* "すべての実績を見る →" */
  .works-more {
    margin-top: 40px;
    text-align: center;
  }

  .works-all-link {
    display: inline-block;
    color: var(--color-text-accent);
    font-family: var(--font-heading);
    font-size: 14px;
    letter-spacing: 0.1em;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .works-all-link:hover {
    color: #ffffff;
  }
</style>

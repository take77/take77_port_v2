---
import { Image } from 'astro:assets';
import SectionTitle from '../common/SectionTitle.astro';
import avatarImg from '../../../avatar.jpg';
---

<section id="about" class="about-section">
  <div class="about-container">
    <SectionTitle accent="About" title="自己紹介" />

    <div class="glass about-card">
      <div class="about-grid">

        <!-- Left Panel: Avatar + Name + Social Links -->
        <div class="about-left">
          <div class="avatar-wrapper">
            <Image
              src={avatarImg}
              alt="take77 / 武田政和 のアバター"
              width={180}
              height={180}
              class="avatar-img"
            />
          </div>

          <div class="name-block">
            <div class="name-primary">take77</div>
            <div class="name-secondary">武田政和</div>
            <div class="name-title">フリーランスエンジニア、とかとか</div>
          </div>

          <div class="social-links">
            <!-- GitHub -->
            <a
              href="https://github.com/take77"
              target="_blank"
              rel="noopener noreferrer"
              title="GitHub"
              class="social-link"
              aria-label="GitHub プロフィール"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
              </svg>
            </a>

            <!-- Zenn -->
            <a
              href="https://zenn.dev/take77"
              target="_blank"
              rel="noopener noreferrer"
              title="Zenn"
              class="social-link"
              aria-label="Zenn 技術記事"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 88 88" fill="currentColor" aria-hidden="true">
                <path d="M9.87 62.4L38.87 8.5A3.01 3.01 0 0 1 41.5 7h10.87a2.56 2.56 0 0 1 2.24 3.77L25.97 65.77A3.02 3.02 0 0 1 23.37 67H12.13A2.56 2.56 0 0 1 9.87 62.4z"/>
                <path d="M49.25 66.87l20.29-35.07a2.56 2.56 0 0 1 2.23-1.3H82.1a2.56 2.56 0 0 1 2.21 3.84l-20 35.06A3.02 3.02 0 0 1 61.7 71H51.49a2.56 2.56 0 0 1-2.24-4.13z"/>
                <path d="M52.6 19.7a3.02 3.02 0 0 1 2.6-1.52h11.93a2.56 2.56 0 0 1 2.22 3.84l-4.68 8.16a2.56 2.56 0 0 1-2.22 1.29H50.5a2.56 2.56 0 0 1-2.23-3.82l4.33-7.95z"/>
              </svg>
            </a>

            <!-- Note -->
            <a
              href="https://note.com/take77_note"
              target="_blank"
              rel="noopener noreferrer"
              title="Note"
              class="social-link"
              aria-label="Note ブログ"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M4 4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2H4zm0 2h16v12H4V6zm2 3a.75.75 0 0 0 0 1.5h12a.75.75 0 0 0 0-1.5H6zm0 3a.75.75 0 0 0 0 1.5h12a.75.75 0 0 0 0-1.5H6zm0 3a.75.75 0 0 0 0 1.5h8a.75.75 0 0 0 0-1.5H6z"/>
              </svg>
            </a>

            <!-- Twitter / X -->
            <a
              href="https://twitter.com/take77_main"
              target="_blank"
              rel="noopener noreferrer"
              title="Twitter / X"
              class="social-link"
              aria-label="Twitter / X プロフィール"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.74l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Right Panel: Bio + Strengths -->
        <div class="about-right">
          <p class="bio-text">
            フリーランスとして企業のシステム開発からHP制作、経営企画等のサポートまで幅広く手がけています。
            スタートアップへの参画や学生起業の経験を活かし、ビジネス視点でのプロダクト開発が強みです。
          </p>

          <div class="strengths">
            <div class="strength-item">
              <div class="strength-icon" aria-hidden="true">🚀</div>
              <div class="strength-text">
                <div class="strength-label">フリーランスの機動力</div>
                <div class="strength-desc">開発観点にとどまらず、皆様にとって最適な解決策を提案します。</div>
              </div>
            </div>

            <div class="strength-item">
              <div class="strength-icon" aria-hidden="true">🔧</div>
              <div class="strength-text">
                <div class="strength-label">フルスタック対応</div>
                <div class="strength-desc">システム開発だけでなく、HP制作や経営企画まで幅広く手がけます。</div>
              </div>
            </div>

            <div class="strength-item">
              <div class="strength-icon" aria-hidden="true">📈</div>
              <div class="strength-text">
                <div class="strength-label">経営視点の開発</div>
                <div class="strength-desc">必要なものを必要なだけ。あなたに最適な提案を。</div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  .about-section {
    padding: 80px clamp(24px, 6vw, 80px);
  }

  .about-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .about-card {
    padding: 0;
    overflow: hidden;
    /* disable default glass hover lift for this card */
    pointer-events: auto;
  }

  .about-card:hover {
    transform: none;
  }

  .about-grid {
    display: grid;
    grid-template-columns: minmax(200px, 280px) 1fr;
  }

  /* ── Left Panel ── */
  .about-left {
    padding: 40px 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 24px;
    border-right: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(139, 92, 246, 0.04);
  }

  .avatar-img {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 0 40px rgba(139, 92, 246, 0.15);
    display: block;
  }

  .name-block {
    text-align: center;
  }

  .name-primary {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 400;
    color: #ffffff;
    letter-spacing: 0.1em;
    margin-bottom: 2px;
  }

  .name-secondary {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.06em;
    margin-bottom: 4px;
  }

  .name-title {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.04em;
    line-height: 1.5;
  }

  /* ── Social Links ── */
  .social-links {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .social-link {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    color: rgba(255, 255, 255, 0.5);
    flex-shrink: 0;
  }

  .social-link:hover {
    background: rgba(139, 92, 246, 0.15);
    border-color: rgba(139, 92, 246, 0.25);
    color: #a78bfa;
  }

  /* ── Right Panel ── */
  .about-right {
    padding: 40px 36px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 28px;
  }

  .bio-text {
    font-size: 0.875rem;
    color: #f0f0f5;
    line-height: 2.2;
    letter-spacing: 0.04em;
    margin: 0;
  }

  /* ── Strength Cards ── */
  .strengths {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding-top: 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .strength-item {
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }

  .strength-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: rgba(139, 92, 246, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 1rem;
    line-height: 1;
  }

  .strength-text {
    flex: 1;
    min-width: 0;
  }

  .strength-label {
    font-size: 0.8125rem;
    color: #ffffff;
    font-weight: 400;
    letter-spacing: 0.04em;
    margin-bottom: 3px;
  }

  .strength-desc {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.7;
  }

  /* ── Responsive: Mobile (≤640px) ── */
  @media (max-width: 640px) {
    .about-section {
      padding: 60px clamp(20px, 5vw, 40px);
    }

    .about-grid {
      grid-template-columns: 1fr;
    }

    .about-left {
      border-right: none;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      padding: 32px 24px;
    }

    .about-right {
      padding: 32px 24px;
    }

    .avatar-img {
      width: 140px;
      height: 140px;
    }
  }
</style>

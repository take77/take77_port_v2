---
import GlassCard from '../common/GlassCard.astro';
import SectionTitle from '../common/SectionTitle.astro';
import SectionWrapper from '../common/SectionWrapper.astro';

const services = [
  {
    id: 'system-development',
    title: 'システム開発',
    titleEn: 'System Development',
    description: '業務システムやWebアプリケーションの設計・開発。要件定義からリリース後の運用保守まで一貫して対応します。',
    href: '/services/system-development',
    icon: `<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>`,
  },
  {
    id: 'web-development',
    title: 'HP開発・運用',
    titleEn: 'Web Development',
    description: 'コーポレートサイト、LP、ECサイトの企画・制作・運用。高速表示とSEOを重視した、成果につながるサイトを構築します。',
    href: '/services/web-development',
    icon: `<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>`,
  },
  {
    id: 'business-planning',
    title: '経営企画',
    titleEn: 'Business Planning',
    description: '事業計画策定、KPI設計、データ分析に基づく経営判断支援。テクノロジーとビジネスの架け橋になります。',
    href: '/services/business-planning',
    icon: `<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>`,
  },
  {
    id: 'video-editing',
    title: '動画編集',
    titleEn: 'Video Editing',
    description: 'プロモーション動画、採用動画、SNS向けショート動画の企画・撮影・編集。ブランドの世界観を映像で表現します。',
    href: '/services/video-editing',
    icon: `<rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"/><line x1="7" y1="2" x2="7" y2="22"/><line x1="17" y1="2" x2="17" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/><line x1="2" y1="7" x2="7" y2="7"/><line x1="2" y1="17" x2="7" y2="17"/><line x1="17" y1="17" x2="22" y2="17"/><line x1="17" y1="7" x2="22" y2="7"/>`,
  },
];
---

<SectionWrapper id="services">
  <SectionTitle title="提供サービス" accent="Services" />
  <div class="services-grid">
    {services.map((service) => (
      <GlassCard href={service.href} hoverable>
        <div class="service-card">
          <div class="service-icon" aria-hidden="true">
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#a78bfa"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              set:html={service.icon}
            />
          </div>
          <p class="service-title-en">{service.titleEn}</p>
          <h3 class="service-title">{service.title}</h3>
          <p class="service-desc">{service.description}</p>
          <span class="service-link">
            詳しく見る
            <svg
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <polyline points="9 18 15 12 9 6" />
            </svg>
          </span>
        </div>
      </GlassCard>
    ))}
  </div>
</SectionWrapper>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-top: 2.5rem;
  }

  .service-card {
    padding: 32px 28px;
  }

  .service-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(139, 92, 246, 0.1);
    border: 1px solid rgba(139, 92, 246, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
    flex-shrink: 0;
  }

  .service-title-en {
    font-family: var(--font-heading);
    font-size: 11px;
    letter-spacing: 0.15em;
    color: var(--color-text-accent);
    margin-bottom: 4px;
    text-transform: uppercase;
  }

  .service-title {
    font-size: 18px;
    font-weight: 400;
    color: var(--color-text-heading);
    margin: 0 0 12px;
    letter-spacing: 0.08em;
    font-family: var(--font-heading);
    line-height: 1.4;
  }

  .service-desc {
    font-size: 13px;
    color: var(--color-text-sub);
    line-height: 1.8;
    margin: 0;
  }

  .service-link {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--color-accent);
    font-size: 13px;
    font-family: var(--font-heading);
    letter-spacing: 0.05em;
    margin-top: 20px;
    transition: gap 0.3s ease, color 0.3s ease;
  }

  /* Hover: glow border + icon accent */
  :global(a.glass):hover .service-link {
    gap: 10px;
    color: var(--color-accent-hover);
  }

  :global(a.glass):hover .service-icon {
    background: rgba(139, 92, 246, 0.18);
    border-color: rgba(139, 92, 246, 0.3);
    box-shadow: 0 0 12px rgba(139, 92, 246, 0.2);
  }

  @media (max-width: 640px) {
    .services-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }
</style>

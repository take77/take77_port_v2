---
// GridPattern - hero section only
// 80px grid lines at opacity 0.04, center-faded with radial gradient mask
---

<div class="grid-pattern" aria-hidden="true" />

<style>
  .grid-pattern {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.04;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.5) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.5) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 40%, black 0%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 40%, black 0%, transparent 70%);
  }

  @media (max-width: 640px) {
    .grid-pattern {
      background-size: 60px 60px;
    }
  }

  @media (prefers-reduced-transparency: reduce) {
    .grid-pattern {
      display: none;
    }
  }
</style>

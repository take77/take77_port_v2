---
// BackgroundBlobs.astro
// 4 animated background blobs with cubic-bezier easing
// spec §5.2 ②: Primary(550px/28s), Pink(480px/24s), Blue(420px/19s), Ambient(350px/35s)
// All filter: blur(80-100px), position: fixed
---

<div class="blobs-container" aria-hidden="true">
  <div class="blob blob-primary"></div>
  <div class="blob blob-pink"></div>
  <div class="blob blob-blue"></div>
  <div class="blob blob-ambient"></div>
</div>

<style>
  .blobs-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  .blob {
    position: absolute;
    border-radius: 50%;
    will-change: transform;
  }

  /* Primary: 550px, purple rgba(139,92,246,0.28), wide elliptical orbit + scale pulse, 28s */
  .blob-primary {
    width: 550px;
    height: 550px;
    background: radial-gradient(circle, rgba(139, 92, 246, 0.28) 0%, transparent 70%);
    filter: blur(80px);
    top: -5%;
    left: 5%;
    animation: blob-primary 28s cubic-bezier(0.45, 0.05, 0.55, 0.95) infinite;
  }

  /* Pink: 480px, pink rgba(236,72,153,0.18), counter-clockwise, asymmetric easing, 24s */
  .blob-pink {
    width: 480px;
    height: 480px;
    background: radial-gradient(circle, rgba(236, 72, 153, 0.18) 0%, transparent 70%);
    filter: blur(90px);
    top: 15%;
    right: -5%;
    animation: blob-pink 24s cubic-bezier(0.25, 0.46, 0.45, 0.94) infinite;
  }

  /* Blue: 420px, blue rgba(59,130,246,0.14), tight orbit, 19s */
  .blob-blue {
    width: 420px;
    height: 420px;
    background: radial-gradient(circle, rgba(59, 130, 246, 0.14) 0%, transparent 70%);
    filter: blur(100px);
    bottom: 10%;
    left: 25%;
    animation: blob-blue 19s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  /* Ambient: 350px, light purple rgba(167,139,250,0.10), ultra-slow drift + opacity pulse, 35s */
  .blob-ambient {
    width: 350px;
    height: 350px;
    background: radial-gradient(circle, rgba(167, 139, 250, 0.10) 0%, transparent 70%);
    filter: blur(80px);
    bottom: 25%;
    right: 15%;
    animation: blob-ambient 35s cubic-bezier(0.37, 0, 0.63, 1) infinite;
  }

  @keyframes blob-primary {
    0%   { transform: translate(0, 0) scale(1); }
    20%  { transform: translate(6vw, 10vh) scale(1.06); }
    40%  { transform: translate(-4vw, 18vh) scale(0.94); }
    60%  { transform: translate(10vw, 8vh) scale(1.08); }
    80%  { transform: translate(3vw, -5vh) scale(0.97); }
    100% { transform: translate(0, 0) scale(1); }
  }

  @keyframes blob-pink {
    0%   { transform: translate(0, 0) scale(1); }
    25%  { transform: translate(-9vw, 12vh) scale(1.07); }
    50%  { transform: translate(-5vw, -10vh) scale(0.93); }
    75%  { transform: translate(-12vw, 4vh) scale(1.05); }
    100% { transform: translate(0, 0) scale(1); }
  }

  @keyframes blob-blue {
    0%   { transform: translate(0, 0) scale(1); }
    33%  { transform: translate(7vw, -12vh) scale(1.05); }
    66%  { transform: translate(-5vw, -6vh) scale(0.96); }
    100% { transform: translate(0, 0) scale(1); }
  }

  @keyframes blob-ambient {
    0%   { transform: translate(0, 0); opacity: 1; }
    20%  { transform: translate(-6vw, 6vh); opacity: 0.65; }
    40%  { transform: translate(4vw, 10vh); opacity: 1; }
    60%  { transform: translate(8vw, -4vh); opacity: 0.75; }
    80%  { transform: translate(-3vw, -8vh); opacity: 0.9; }
    100% { transform: translate(0, 0); opacity: 1; }
  }

  /* Stop all blob animations when user prefers reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .blob {
      animation: none;
    }
  }
</style>

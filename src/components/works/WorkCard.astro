---
import DuotoneImage from '../common/DuotoneImage.astro';
import type { ImageMetadata } from 'astro';

interface Props {
  slug: string;
  title: string;
  description: string;
  thumbnail: ImageMetadata;
  serviceCategory: string[];
  themeColor?: string;
}

const {
  slug,
  title,
  description,
  thumbnail,
  serviceCategory,
  themeColor = '#8b5cf6',
} = Astro.props;

const categoryLabels: Record<string, string> = {
  'system-development': 'システム開発',
  'web-development': 'HP開発・運用',
  'business-planning': '経営企画',
  'video-editing': '動画編集',
};
---

<a href={`/works/${slug}`} class="work-card">
  <div class="card-image">
    <DuotoneImage
      src={thumbnail}
      alt={title}
      width={400}
      height={225}
      themeColor={themeColor}
    />
  </div>
  <div class="card-body">
    <div class="card-tags">
      {serviceCategory.map((cat) => (
        <span class="card-tag">{categoryLabels[cat] ?? cat}</span>
      ))}
    </div>
    <h3 class="card-title">{title}</h3>
    <p class="card-description">{description}</p>
    <span class="card-link">詳しく見る →</span>
  </div>
</a>

<style>
  .work-card {
    display: block;
    background: var(--glass-bg, rgba(255, 255, 255, 0.09));
    backdrop-filter: blur(var(--glass-blur, 20px)) saturate(var(--glass-saturate, 200%));
    -webkit-backdrop-filter: blur(var(--glass-blur, 20px)) saturate(var(--glass-saturate, 200%));
    border: 1px solid var(--glass-border, rgba(255, 255, 255, 0.18));
    border-radius: 0.75rem;
    overflow: hidden;
    text-decoration: none;
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow:
      0 8px 32px var(--glass-shadow, rgba(0, 0, 0, 0.4)),
      inset 0 1px 0 var(--glass-highlight, rgba(255, 255, 255, 0.28)),
      inset 0 0 20px var(--glass-glow, rgba(255, 255, 255, 0.04));
  }

  .work-card:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.28);
    box-shadow:
      0 16px 40px var(--glass-shadow, rgba(0, 0, 0, 0.4)),
      inset 0 1px 0 var(--glass-highlight, rgba(255, 255, 255, 0.28)),
      inset 0 0 24px var(--glass-glow, rgba(255, 255, 255, 0.04));
  }

  .card-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .card-body {
    padding: 24px 28px;
  }

  .card-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }

  .card-tag {
    font-size: 0.625rem;
    padding: 3px 10px;
    border-radius: 9999px;
    background: rgba(139, 92, 246, 0.2);
    color: #a78bfa;
    letter-spacing: 0.05em;
    font-family: 'Jost', sans-serif;
  }

  .card-title {
    font-size: 1rem;
    font-weight: 600;
    color: #ffffff;
    margin: 0 0 8px;
    line-height: 1.5;
    letter-spacing: 0.02em;
    font-family: 'Jost', 'Sawarabi Gothic', sans-serif;
  }

  .card-description {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.5);
    margin: 0 0 16px;
    line-height: 1.7;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-link {
    font-size: 0.75rem;
    color: #a78bfa;
    font-family: 'Jost', sans-serif;
    letter-spacing: 0.05em;
    transition: color 0.2s ease;
  }

  .work-card:hover .card-link {
    color: #c4b5fd;
  }

  @media (prefers-reduced-transparency: reduce) {
    .work-card {
      background: rgba(30, 15, 40, 0.95);
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
    }
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="take77 Portfolio v2 — Phase 1">
  <main style="display: flex; align-items: center; justify-content: center; min-height: 100vh; text-align: center; padding: 2rem;">
    <div>
      <h1 style="font-family: var(--font-heading); font-size: clamp(2rem, 5vw, 4rem); font-weight: 600; margin-bottom: 1rem; background: linear-gradient(135deg, #fff 0%, #a78bfa 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
        take77 Portfolio v2
      </h1>
      <p style="color: var(--color-text-sub); font-size: 1.1rem; letter-spacing: 0.1em;">
        Phase 1 — Foundation Complete
      </p>
      <p style="margin-top: 1.5rem; color: var(--color-text-accent); font-size: 0.9rem;">
        Technology meets Creativity
      </p>
    </div>
  </main>
</BaseLayout>

---
import ServiceDetailLayout from '../../components/ServiceDetailLayout.astro';

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  provider: { '@type': 'Person', name: 'take77' },
  name: '動画編集',
  description: 'YouTube動画からプロモーション映像まで。企画・撮影サポートから編集・納品まで、映像制作をトータルでサポートします。',
  url: 'https://take77-port.com/services/video-editing',
};

const checkIcon = '<polyline points="20 6 9 17 4 12" />';

const features = [
  { icon: checkIcon, label: 'YouTube動画編集・エフェクト制作' },
  { icon: checkIcon, label: 'モーショングラフィックス' },
  { icon: checkIcon, label: '動画コンテンツ企画・構成' },
  { icon: checkIcon, label: '編集テンプレート整備・制作フロー構築' },
];
---

<ServiceDetailLayout
  pageTitle="動画編集 | take77"
  pageDescription="YouTube動画からプロモーション映像まで。企画・撮影サポートから編集・納品まで、映像制作をトータルでサポートします。"
  breadcrumbLabel="動画編集"
  iconSvg="<polygon points='23 7 16 12 23 17 23 7' /><rect x='1' y='5' width='15' height='14' rx='2' ry='2' />"
  title="動画編集"
  subtitle="Video Editing"
  leadText="YouTube動画からプロモーション映像まで。企画・撮影サポートから編集・納品まで、映像制作をトータルでサポートします。"
  bodyText="登録者1.5万人・動画150本規模のYouTubeチャンネルに長期参画し、エフェクト・テンプレート整備による制作効率化を経験。Adobe After Effects / Premiere Proを組み合わせた動画演出が得意領域です。"
  features={features}
  category="video-editing"
  serviceJsonLd={serviceJsonLd}
/>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/common/Breadcrumb.astro';
import SectionTitle from '../../components/common/SectionTitle.astro';
import GlassCard from '../../components/common/GlassCard.astro';
import DuotoneImage from '../../components/common/DuotoneImage.astro';
import ContactSection from '../../components/contact/ContactSection.tsx';
import { getCollection } from 'astro:content';

const works = await getCollection('works', ({ data }) =>
  !data.draft && data.serviceCategory.includes('web-development')
);
const sortedWorks = works.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  provider: { '@type': 'Person', name: 'take77' },
  name: 'HP開発・運用',
  description: 'コーポレートサイトからランディングページ、Webアプリまで。デザインから実装、運用まで一貫してサポートします。',
  url: 'https://take77-port.com/services/web-development',
};
---

<BaseLayout
  title="HP開発・運用 | take77"
  description="コーポレートサイトからランディングページ、Webアプリまで。デザインから実装、運用まで一貫してサポートします。"
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceJsonLd)} />

  <!-- Breadcrumb -->
  <div class="breadcrumb-area">
    <Breadcrumb items={[
      { label: 'ホーム', href: '/' },
      { label: 'HP開発・運用' },
    ]} />
  </div>

  <!-- Service Hero -->
  <section class="section">
    <div class="section-inner">
      <!-- Service Icon -->
      <div class="service-icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10" />
          <line x1="2" y1="12" x2="22" y2="12" />
          <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
        </svg>
      </div>

      <SectionTitle
        title="HP開発・運用"
        subtitle="Web Development"
        accent="Service"
      />

      <!-- Service description -->
      <div class="service-description">
        <p class="service-lead">
          コーポレートサイトからランディングページ、Webアプリまで。
          デザインから実装、運用まで一貫してサポートします。
          ビジネスの目的に合わせた最適なWebサイトを、
          スピード感を持ってお届けします。
        </p>
        <p class="service-body">
          SEO・パフォーマンス・アクセシビリティを標準として設計し、
          制作後の更新・保守まで安心してお任せいただける体制を整えています。
          CMSの導入でコンテンツ更新を内製化したいお客様にも対応しています。
        </p>
      </div>

      <!-- Features list -->
      <GlassCard class="features-card">
        <div class="features-inner">
        <h3 class="features-heading">提供内容</h3>
        <ul class="features-list" role="list">
          <li class="feature-item">
            <svg class="feature-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2" /><line x1="3" y1="9" x2="21" y2="9" /><line x1="9" y1="21" x2="9" y2="9" />
            </svg>
            <span class="feature-text">コーポレートサイト制作・リニューアル</span>
          </li>
          <li class="feature-item">
            <svg class="feature-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" />
            </svg>
            <span class="feature-text">ランディングページ（LP）制作</span>
          </li>
          <li class="feature-item">
            <svg class="feature-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
            </svg>
            <span class="feature-text">CMS導入・カスタマイズ</span>
          </li>
          <li class="feature-item">
            <svg class="feature-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="5" y="2" width="14" height="20" rx="2" ry="2" /><line x1="12" y1="18" x2="12.01" y2="18" />
            </svg>
            <span class="feature-text">レスポンシブデザイン対応</span>
          </li>
          <li class="feature-item">
            <svg class="feature-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="23 6 13.5 15.5 8.5 10.5 1 18" /><polyline points="17 6 23 6 23 12" />
            </svg>
            <span class="feature-text">SEO対策・パフォーマンス最適化</span>
          </li>
        </ul>
        </div>
      </GlassCard>
    </div>
  </section>

  <!-- Related Works -->
  {sortedWorks.length > 0 && (
    <section class="section section-works">
      <div class="section-inner">
        <SectionTitle title="関連実績" accent="Works" />
        <div class="works-grid">
          {sortedWorks.map((work) => (
            <GlassCard href={`/works/${work.id}`} hoverable class="work-card">
              <div class="work-image-wrap">
                <DuotoneImage
                  src={work.data.thumbnail}
                  alt={work.data.title}
                  width={600}
                  height={400}
                  themeColor="#6366f1"
                />
              </div>
              <div class="work-body">
                <h3 class="work-title">{work.data.title}</h3>
                <p class="work-description">{work.data.description}</p>
                <span class="work-link" aria-hidden="true">詳しく見る →</span>
              </div>
            </GlassCard>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Contact -->
  <ContactSection client:visible />
</BaseLayout>

<style>
  .breadcrumb-area {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 2rem 0;
  }

  .section {
    position: relative;
    padding: 6rem 2rem;
  }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  .service-icon {
    color: var(--color-accent);
    margin-bottom: 1.5rem;
  }

  .service-description {
    margin-bottom: 3rem;
  }

  .service-lead {
    font-size: 1.1rem;
    line-height: 1.9;
    color: var(--color-text);
    margin-bottom: 1.25rem;
    max-width: 720px;
  }

  .service-body {
    font-size: 0.95rem;
    line-height: 1.9;
    color: var(--color-text-sub);
    max-width: 720px;
  }

  .features-card {
    max-width: 720px;
  }

  .features-inner {
    padding: 1.5rem 2rem;
  }

  /* Disable hover animation — 提供内容カードはリンクなし */
  .features-card:hover {
    transform: none;
    border-color: var(--glass-border);
    box-shadow:
      0 8px 32px var(--glass-shadow),
      inset 0 1px 0 var(--glass-highlight),
      inset 0 0 20px var(--glass-glow);
    cursor: default;
  }

  .features-heading {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--color-text-heading);
    margin-bottom: 1.5rem;
  }

  .features-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.125rem;
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }

  .feature-icon {
    flex-shrink: 0;
    color: var(--color-accent);
  }

  .feature-text {
    font-size: 0.975rem;
    color: var(--color-text);
    line-height: 1.6;
  }

  /* Related works */
  .section-works {
    padding-top: 0;
  }

  .works-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .work-card {
    overflow: hidden;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .work-image-wrap {
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }

  .work-body {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .work-title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text-heading);
    line-height: 1.4;
  }

  .work-description {
    font-size: 0.875rem;
    color: var(--color-text-sub);
    line-height: 1.7;
    flex: 1;
  }

  .work-link {
    font-size: 0.8rem;
    color: var(--color-text-accent);
    font-family: var(--font-heading);
    letter-spacing: 0.05em;
    margin-top: 0.25rem;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .breadcrumb-area {
      padding: 1.5rem 1.5rem 0;
    }

    .section {
      padding: 4rem 1.5rem;
    }

    .features-inner {
      padding: 1.25rem 1.5rem;
    }

    .works-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import ServiceDetailLayout from '../../components/ServiceDetailLayout.astro';

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  provider: { '@type': 'Person', name: 'take77' },
  name: '経営企画',
  description: '技術が分かるからこそ、実現可能性を即座に判断できます。仮説検証型で小さく回しながら事業の成長を支えます。',
  url: 'https://take77-port.com/services/business-planning',
};

const checkIcon = '<polyline points="20 6 9 17 4 12" />';

const features = [
  { icon: checkIcon, label: '事業計画策定・収支シミュレーション' },
  { icon: checkIcon, label: '新規事業立ち上げ支援' },
  { icon: checkIcon, label: 'スタートアップの創業期〜成長期の経営サポート' },
  { icon: checkIcon, label: 'KPI設計・モニタリング体制構築' },
  { icon: checkIcon, label: '資金調達戦略の検討支援' },
];
---

<ServiceDetailLayout
  pageTitle="経営企画 | take77"
  pageDescription="技術が分かるからこそ、実現可能性を即座に判断できます。仮説検証型で小さく回しながら事業の成長を支えます。"
  breadcrumbLabel="経営企画"
  iconSvg="<line x1='18' y1='20' x2='18' y2='10' /><line x1='12' y1='20' x2='12' y2='4' /><line x1='6' y1='20' x2='6' y2='14' />"
  title="経営企画"
  subtitle="Business Planning"
  leadText="技術が分かるからこそ、「それは実現できるのか」「どれくらいかかるのか」を即座に判断できます。絵に描いた餅にならない、地に足のついた事業計画を一緒につくります。"
  bodyText="スタートアップの創業期に事業責任者として参画し、事業計画策定・チームマネジメント・資金調達まで一貫してサポートした経験があります。大きな計画より小さな仮説検証の繰り返しで、着実に事業を前に進めます。"
  features={features}
  category="business-planning"
  serviceJsonLd={serviceJsonLd}
/>

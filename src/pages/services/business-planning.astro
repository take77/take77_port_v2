---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/common/Breadcrumb.astro';
import SectionTitle from '../../components/common/SectionTitle.astro';
import GlassCard from '../../components/common/GlassCard.astro';
import DuotoneImage from '../../components/common/DuotoneImage.astro';
import ContactSection from '../../components/contact/ContactSection.tsx';
import { getCollection } from 'astro:content';

const works = await getCollection('works', ({ data }) =>
  !data.draft && data.serviceCategory.includes('business-planning')
);
const sortedWorks = works.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const serviceItems = [
  '事業計画策定・収支シミュレーション',
  '新規事業立ち上げ支援',
  '市場調査・競合分析',
  'KPI設計・モニタリング体制構築',
  '経営会議資料作成支援',
];

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  provider: { '@type': 'Person', name: 'take77' },
  name: '経営企画',
  description: '事業計画の策定から新規事業の立ち上げ支援まで。データに基づく意思決定と戦略立案で、ビジネスの成長を加速します。',
  url: 'https://take77-port.com/services/business-planning',
};
---

<BaseLayout
  title="経営企画 | take77"
  description="事業計画の策定から新規事業の立ち上げ支援まで。データに基づく意思決定と戦略立案で、ビジネスの成長を加速します。"
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceJsonLd)} />

  <!-- Breadcrumb -->
  <div class="breadcrumb-area">
    <Breadcrumb items={[
      { label: 'ホーム', href: '/' },
      { label: '経営企画' },
    ]} />
  </div>

  <!-- Service Detail Section -->
  <section class="section">
    <div class="section-inner">
      <!-- Service Icon -->
      <div class="service-icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="20" x2="18" y2="10" />
          <line x1="12" y1="20" x2="12" y2="4" />
          <line x1="6" y1="20" x2="6" y2="14" />
        </svg>
      </div>

      <SectionTitle title="経営企画" subtitle="Business Planning" accent="Service" />

      <!-- Service description -->
      <div class="service-description">
        <p class="service-lead">
          事業計画の策定から新規事業の立ち上げ支援まで。データに基づく意思決定と戦略立案で、ビジネスの成長を加速します。
        </p>
      </div>

      <!-- Features list -->
      <GlassCard class="features-card">
        <h3 class="features-heading">提供内容</h3>
        <ul class="features-list" role="list">
          {serviceItems.map((item) => (
            <li class="feature-item">
              <svg class="feature-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="20 6 9 17 4 12" />
              </svg>
              <span class="feature-text">{item}</span>
            </li>
          ))}
        </ul>
      </GlassCard>
    </div>
  </section>

  <!-- Related Works (hidden if empty) -->
  {sortedWorks.length > 0 && (
    <section class="section section-works">
      <div class="section-inner">
        <SectionTitle title="関連実績" accent="Works" />
        <div class="works-grid">
          {sortedWorks.map((work) => (
            <GlassCard href={`/works/${work.id}`} hoverable class="work-card">
              <div class="work-image-wrap">
                <DuotoneImage
                  src={work.data.thumbnail}
                  alt={work.data.title}
                  width={600}
                  height={400}
                  themeColor="#8b5cf6"
                />
              </div>
              <div class="work-body">
                <h3 class="work-title">{work.data.title}</h3>
                <p class="work-description">{work.data.description}</p>
                <span class="work-link" aria-hidden="true">詳しく見る →</span>
              </div>
            </GlassCard>
          ))}
        </div>
      </div>
    </section>
  )}

  <ContactSection client:visible />
</BaseLayout>

<style>
  .breadcrumb-area {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 2rem 0;
  }

  .section {
    position: relative;
    padding: 6rem 2rem;
  }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  .service-icon {
    color: var(--color-accent);
    margin-bottom: 1.5rem;
  }

  .service-description {
    margin-bottom: 3rem;
  }

  .service-lead {
    font-size: 1.1rem;
    line-height: 1.9;
    color: var(--color-text);
    max-width: 720px;
  }

  .features-card {
    padding: 2.5rem;
    max-width: 720px;
  }

  /* Disable hover animation — 提供内容カードはリンクなし */
  .features-card:hover {
    transform: none;
    border-color: var(--glass-border);
    box-shadow:
      0 8px 32px var(--glass-shadow),
      inset 0 1px 0 var(--glass-highlight),
      inset 0 0 20px var(--glass-glow);
    cursor: default;
  }

  .features-heading {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--color-text-heading);
    margin-bottom: 1.5rem;
  }

  .features-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.125rem;
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }

  .feature-icon {
    flex-shrink: 0;
    color: var(--color-accent);
  }

  .feature-text {
    font-size: 0.975rem;
    color: var(--color-text);
    line-height: 1.6;
  }

  /* Related works */
  .section-works {
    padding-top: 0;
  }

  .works-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .work-card {
    overflow: hidden;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .work-image-wrap {
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }

  .work-body {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .work-title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text-heading);
    line-height: 1.4;
  }

  .work-description {
    font-size: 0.875rem;
    color: var(--color-text-sub);
    line-height: 1.7;
    flex: 1;
  }

  .work-link {
    font-size: 0.8rem;
    color: var(--color-text-accent);
    font-family: var(--font-heading);
    letter-spacing: 0.05em;
    margin-top: 0.25rem;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .breadcrumb-area {
      padding: 1.5rem 1.5rem 0;
    }

    .section {
      padding: 4rem 1.5rem;
    }

    .features-card {
      padding: 1.75rem;
    }

    .works-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

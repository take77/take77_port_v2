---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/common/Breadcrumb.astro';
import SectionTitle from '../../components/common/SectionTitle.astro';
import GlassCard from '../../components/common/GlassCard.astro';
import DuotoneImage from '../../components/common/DuotoneImage.astro';
import ContactSection from '../../components/contact/ContactSection.tsx';
import { getCollection } from 'astro:content';

const works = await getCollection('works', ({ data }) =>
  !data.draft && data.serviceCategory.includes('business-planning')
);
const sortedWorks = works.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const serviceItems = [
  '事業計画策定・収支シミュレーション',
  '新規事業立ち上げ支援',
  '市場調査・競合分析',
  'KPI設計・モニタリング体制構築',
  '経営会議資料作成支援',
];

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  provider: { '@type': 'Person', name: 'take77' },
  name: '経営企画',
  description: '事業計画の策定から新規事業の立ち上げ支援まで。データに基づく意思決定と戦略立案で、ビジネスの成長を加速します。',
  url: 'https://take77-port.com/services/business-planning',
};
---

<BaseLayout
  title="経営企画 | take77"
  description="事業計画の策定から新規事業の立ち上げ支援まで。データに基づく意思決定と戦略立案で、ビジネスの成長を加速します。"
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceJsonLd)} />
  <div class="breadcrumb-area">
    <Breadcrumb items={[
      { label: 'ホーム', href: '/' },
      { label: '経営企画' },
    ]} />
  </div>

  <!-- Service Detail Section -->
  <section class="section">
    <div class="section-inner">
      <div class="service-icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="20" x2="18" y2="10" />
          <line x1="12" y1="20" x2="12" y2="4" />
          <line x1="6" y1="20" x2="6" y2="14" />
        </svg>
      </div>
      <SectionTitle title="経営企画" subtitle="Business Planning" accent="Service" />
      <p class="service-description">
        事業計画の策定から新規事業の立ち上げ支援まで。データに基づく意思決定と戦略立案で、ビジネスの成長を加速します。
      </p>
      <div class="offerings">
        <h3 class="offerings-heading">提供内容</h3>
        <ul class="offerings-list">
          {serviceItems.map((item) => (
            <li class="offerings-item">
              <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="20 6 9 17 4 12" />
              </svg>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Related Works (hidden if empty) -->
  {sortedWorks.length > 0 && (
    <section class="section section-works">
      <div class="section-inner">
        <SectionTitle title="関連実績" accent="Works" />
        <div class="works-grid">
          {sortedWorks.map((work) => (
            <GlassCard href={`/works/${work.id}`} hoverable class="work-card">
              <div class="work-thumbnail">
                <DuotoneImage
                  src={work.data.thumbnail}
                  alt={work.data.title}
                  width={640}
                  height={360}
                  themeColor="#8b5cf6"
                />
              </div>
              <div class="work-info">
                <h3 class="work-title">{work.data.title}</h3>
                <p class="work-desc">{work.data.description}</p>
              </div>
            </GlassCard>
          ))}
        </div>
      </div>
    </section>
  )}

  <ContactSection client:visible />
</BaseLayout>

<style>
  .breadcrumb-area {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 2rem 0;
  }

  .section {
    padding: 6rem 2rem;
  }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .service-icon {
    color: var(--color-accent);
    margin-bottom: 1.5rem;
  }

  .service-description {
    font-size: 1.1rem;
    color: var(--color-text);
    line-height: 1.9;
    max-width: 720px;
    margin-bottom: 3rem;
  }

  .offerings {
    max-width: 720px;
  }

  .offerings-heading {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-accent);
    margin-bottom: 1.25rem;
  }

  .offerings-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .offerings-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.6;
  }

  .check-icon {
    flex-shrink: 0;
    color: var(--color-accent);
  }

  .section-works {
    padding-top: 0;
  }

  .works-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .work-card {
    overflow: hidden;
    padding: 0;
  }

  .work-thumbnail {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .work-info {
    padding: 1.25rem 1.5rem 1.5rem;
  }

  .work-title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text-heading);
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }

  .work-desc {
    font-size: 0.875rem;
    color: var(--color-text-sub);
    line-height: 1.7;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 640px) {
    .breadcrumb-area {
      padding: 1.5rem 1.5rem 0;
    }

    .section {
      padding: 4rem 1.5rem;
    }

    .works-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

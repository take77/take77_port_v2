---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/common/Breadcrumb.astro';
import SectionTitle from '../../components/common/SectionTitle.astro';
import GlassCard from '../../components/common/GlassCard.astro';
import DuotoneImage from '../../components/common/DuotoneImage.astro';
import ContactSection from '../../components/contact/ContactSection.tsx';
import { getCollection } from 'astro:content';

const works = await getCollection('works', ({ data }) =>
  !data.draft && data.serviceCategory.includes('system-development')
);
const sortedWorks = works.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  provider: { '@type': 'Person', name: 'take77' },
  name: 'システム開発',
  description: 'Webアプリケーション開発からAPI設計、クラウドインフラ構築まで、ビジネスの成長を支えるシステムを設計・開発します。',
  url: 'https://take77-port.com/services/system-development',
};
---

<BaseLayout
  title="システム開発 | take77"
  description="Webアプリケーション開発からAPI設計、クラウドインフラ構築まで、ビジネスの成長を支えるシステムを設計・開発します。"
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceJsonLd)} />

  <!-- Breadcrumb -->
  <div class="breadcrumb-area">
    <Breadcrumb items={[
      { label: 'ホーム', href: '/' },
      { label: 'システム開発' },
    ]} />
  </div>

  <!-- Service Hero -->
  <section class="section">
    <div class="section-inner">
      <!-- Service Icon -->
      <div class="service-icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="16 18 22 12 16 6" />
          <polyline points="8 6 2 12 8 18" />
        </svg>
      </div>

      <SectionTitle
        title="システム開発"
        subtitle="System Development"
        accent="Service"
      />

      <!-- Service description -->
      <div class="service-description">
        <p class="service-lead">
          Webアプリケーション開発からAPI設計、クラウドインフラ構築まで、
          ビジネスの成長を支えるシステムを設計・開発します。
          要件定義から設計、実装、運用まで一貫して対応し、
          スケーラブルで保守性の高いシステムを提供します。
        </p>
        <p class="service-body">
          フルスタック開発の経験を活かし、フロントエンドからバックエンド、
          インフラまでトータルにサポート。
          モダンな技術スタックと確立されたベストプラクティスで、
          長期的に価値を生み出すシステムをご提供します。
        </p>
      </div>

      <!-- Features list -->
      <GlassCard class="features-card">
        <div class="features-inner">
        <h3 class="features-heading">提供内容</h3>
        <ul class="features-list" role="list">
          <li class="feature-item">
            <svg class="feature-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="3" width="20" height="14" rx="2" ry="2" /><line x1="8" y1="21" x2="16" y2="21" /><line x1="12" y1="17" x2="12" y2="21" />
            </svg>
            <span class="feature-text">Webアプリケーション設計・開発</span>
          </li>
          <li class="feature-item">
            <svg class="feature-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="16 18 22 12 16 6" /><polyline points="8 6 2 12 8 18" />
            </svg>
            <span class="feature-text">REST API / GraphQL API 設計・実装</span>
          </li>
          <li class="feature-item">
            <svg class="feature-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z" />
            </svg>
            <span class="feature-text">クラウドインフラ構築（AWS / GCP）</span>
          </li>
          <li class="feature-item">
            <svg class="feature-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <ellipse cx="12" cy="5" rx="9" ry="3" /><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3" /><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5" />
            </svg>
            <span class="feature-text">データベース設計・最適化</span>
          </li>
          <li class="feature-item">
            <svg class="feature-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="6" y1="3" x2="6" y2="15" /><circle cx="18" cy="6" r="3" /><circle cx="6" cy="18" r="3" /><path d="M18 9a9 9 0 0 1-9 9" />
            </svg>
            <span class="feature-text">CI/CD パイプライン構築</span>
          </li>
        </ul>
        </div>
      </GlassCard>
    </div>
  </section>

  <!-- Related Works -->
  {sortedWorks.length > 0 && (
    <section class="section section-works">
      <div class="section-inner">
        <SectionTitle title="関連実績" accent="Works" />
        <div class="works-grid">
          {sortedWorks.map((work) => (
            <GlassCard href={`/works/${work.id}`} hoverable class="work-card">
              <div class="work-image-wrap">
                <DuotoneImage
                  src={work.data.thumbnail}
                  alt={work.data.title}
                  width={600}
                  height={400}
                  themeColor="#8b5cf6"
                />
              </div>
              <div class="work-body">
                <h3 class="work-title">{work.data.title}</h3>
                <p class="work-description">{work.data.description}</p>
                <span class="work-link" aria-hidden="true">詳しく見る →</span>
              </div>
            </GlassCard>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Contact -->
  <ContactSection client:visible />
</BaseLayout>

<style>
  .breadcrumb-area {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 2rem 0;
  }

  .section {
    position: relative;
    padding: 6rem 2rem;
  }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  .service-icon {
    color: var(--color-accent);
    margin-bottom: 1.5rem;
  }

  .service-description {
    margin-bottom: 3rem;
  }

  .service-lead {
    font-size: 1.1rem;
    line-height: 1.9;
    color: var(--color-text);
    margin-bottom: 1.25rem;
    max-width: 720px;
  }

  .service-body {
    font-size: 0.95rem;
    line-height: 1.9;
    color: var(--color-text-sub);
    max-width: 720px;
  }

  .features-card {
    max-width: 720px;
  }

  .features-inner {
    padding: 1.5rem 2rem;
  }

  /* Disable hover animation — 提供内容カードはリンクなし */
  .features-card:hover {
    transform: none;
    border-color: var(--glass-border);
    box-shadow:
      0 8px 32px var(--glass-shadow),
      inset 0 1px 0 var(--glass-highlight),
      inset 0 0 20px var(--glass-glow);
    cursor: default;
  }

  .features-heading {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--color-text-heading);
    margin-bottom: 1.5rem;
  }

  .features-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.125rem;
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }

  .feature-icon {
    flex-shrink: 0;
    color: var(--color-accent);
  }

  .feature-text {
    font-size: 0.975rem;
    color: var(--color-text);
    line-height: 1.6;
  }

  /* Related works */
  .section-works {
    padding-top: 0;
  }

  .works-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .work-card {
    overflow: hidden;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .work-image-wrap {
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }

  .work-body {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .work-title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text-heading);
    line-height: 1.4;
  }

  .work-description {
    font-size: 0.875rem;
    color: var(--color-text-sub);
    line-height: 1.7;
    flex: 1;
  }

  .work-link {
    font-size: 0.8rem;
    color: var(--color-text-accent);
    font-family: var(--font-heading);
    letter-spacing: 0.05em;
    margin-top: 0.25rem;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .breadcrumb-area {
      padding: 1.5rem 1.5rem 0;
    }

    .section {
      padding: 4rem 1.5rem;
    }

    .features-inner {
      padding: 1.25rem 1.5rem;
    }

    .works-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
